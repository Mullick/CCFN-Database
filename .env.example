# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jail_roster
DB_USER=jailapp
DB_PASS=CHANGE_THIS_STRONG_PASSWORD

# File paths
PHOTO_DIR=/var/www/jailroster/photos
REPORTS_DIR=/var/www/jailroster/reports

# Scraper mode: 'url' to fetch live PDF, 'file' to parse a local PDF
SCRAPE_MODE=url
SCRAPE_URL=https://jailroster.co.carlton.mn.us/CCJ_Jail_Roster.pdf

# Only used when SCRAPE_MODE=file:
# SCRAPE_FILE=/path/to/historical/CCJ_Jail_Roster.pdf
